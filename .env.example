# ── Tahmin Platformu — Environment Variables ──
# Copy to .env and fill in values. All have sensible defaults.

# Admin account (created on first launch)
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeThisPassword123!

# Data persistence (set to network volume path on RunPod)
DATA_DIR=/app/data

# Server
HOST=0.0.0.0
PORT=8080

# Cookie security (set to true when behind HTTPS proxy)
SECURE_COOKIES=false

# Trusted reverse proxy IPs (comma-separated, for X-Forwarded-For)
# TRUSTED_PROXY_IPS=127.0.0.1,172.17.0.1

# CORS (comma-separated allowed origins, empty = allow all)
# CORS_ORIGINS=https://yourdomain.com

# LLM (auto-downloads and manages llama.cpp)
LLAMA_BUNDLED=auto
# LLAMA_MODEL_REPO=unsloth/Qwen3.5-4B-GGUF
# LLAMA_MODEL_FILE=Qwen3.5-4B-Q4_K_M.gguf

# Whisper STT
# WHISPER_DEVICE=auto
# WHISPER_IDLE_TIMEOUT=300

# Ray/AutoGluon CPU detection fix for containers (vast.ai, RunPod, Docker)
RAY_USE_MULTIPROCESSING_CPU_COUNT=1

# Cloudflare Tunnel (exposes app via your domain without opening ports)
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
